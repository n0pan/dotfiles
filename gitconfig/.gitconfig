# This is Git's per-user configuration file.
[user]
# Please adapt and uncomment the following lines:
	name = LQ Hoang
	email = longquanhp@gmail.com
[alias]
  ci = commit
  cam = commit -a -m
  cm = commit -m
  co = checkout
  b = branch
  nb = branch -b
  s = status
[core]
	excludesfile = /Users/long-quanhoang-pham/.gitignore_global
[difftool "sourcetree"]
	cmd = opendiff \"$LOCAL\" \"$REMOTE\"
	path = 
[mergetool "sourcetree"]
	cmd = /Applications/Sourcetree.app/Contents/Resources/opendiff-w.sh \"$LOCAL\" \"$REMOTE\" -ancestor \"$BASE\" -merge \"$MERGED\"
	trustExitCode = true
[commit]
	template = /Users/long-quanhoang-pham/.stCommitMsg
